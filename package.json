{
  "name": "shodhganga-pdfmerger",
  "version": "1.0.0",
  "description": "Shodhganga PDF Merger Electron App",
  "author": "www.indianotify.com",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.indianotify.shodhganga-pdfmerger",
    "productName": "Shodhganga-PDFmerger",
    "icon": "assets/icon.png",
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "cheerio": "^1.0.0",
    "p-limit": "^3.1.0",
    "pdf-lib": "^1.17.1",
    "pdf-merger-js": "^5.1.2"
  }
}
